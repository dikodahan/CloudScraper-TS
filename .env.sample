# Copy to .env for local testing. Values here are not committed.
# FlareSolverr: if set, the default orchestrate solver will use it first (e.g. Docker: http://localhost:8191/v1).
# FLARESOLVERR_URL=http://localhost:8191/v1

# Browserless: optional remote browser (Browsers-as-a-Service). Prefer Playwright on a private server.
# When set, the default orchestrate solver will use Browserless after FlareSolverr.
# Requires puppeteer-core in the consuming project.
# Example (Browserless cloud, replace token):
# BROWSERLESS_WS_ENDPOINT=wss://production-sfo.browserless.io?token=YOUR_API_KEY

# On a private Node server, prefer: npm install playwright && npx playwright install chromium
# No env var is required for local Playwright; createDefaultOrchestrateSolver() will use it.