{
  "name": "cloudscraper-ts",
  "version": "1.1.0",
  "description": "Bypasses some anti-bot pages made by CloudFlare.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "node test/server.js run",
    "test:server": "node test/server.js",
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "prepare": "npm run build",
    "eslint": "eslint .",
    "prettier": "prettier --write .",
    "lint": "npm run eslint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dikodahan/CloudScraper-TS.git"
  },
  "author": "eltik",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dikodahan/CloudScraper-TS/issues"
  },
  "homepage": "https://github.com/dikodahan/CloudScraper-TS#readme",
  "dependencies": {
    "got": "^15.1.0",
    "tough-cookie": "^6.0.2"
  },
  "peerDependencies": {
    "playwright": "*",
    "puppeteer": "*",
    "puppeteer-core": "*"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    },
    "puppeteer-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^24.13.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.5",
    "playwright": "^1.58.2",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
